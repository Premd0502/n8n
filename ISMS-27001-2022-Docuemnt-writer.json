              "value": "=[\n  {\n    \"control\": \"A.8.28 Secure Coding\",\n    \"evidence_type\": \"Process\",\n    \"description\": \"Secure coding guidelines implemented\",\n    \"proof\": \"Internal policy document\",\n    \"owner\": \"Development Team\",\n    \"review_date\": \"2026-04-01\"\n  },\n  {\n    \"control\": \"A.8.25 Secure Development Lifecycle\",\n    \"evidence_type\": \"Tool\",\n    \"description\": \"SAST/DAST implemented\",\n    \"proof\": \"Scan reports\",\n    \"owner\": \"Security Team\",\n    \"review_date\": \"2026-04-01\"\n  }\n]",
