      "typeVersion": 3.4
    },
    {
      "parameters": {
        "functionCode": "const policy = $json[\"Policy Name\"];\nconst team = $json[\"Team\"];\nconst evidence = $json[\"Evidence\"];\n\nlet evidenceText = \"\";\n\nif (Array.isArray(evidence)) {\n  evidenceText = evidence.map((e, i) => {\n    return `\n${i+1}. Control: ${e.control}\n   Type: ${e.evidence_type}\n   Description: ${e.description}\n   Proof: ${e.proof}\n   Owner: ${e.owner}\n   Review Date: ${e.review_date}\n`;\n  }).join(\"\\n\");\n} else {\n  evidenceText = \"No evidence provided\";\n}\n\nconst document = `\nISMS POLICY DOCUMENT\n\n1. Policy Name:\n${policy}\n\n2. Purpose:\nTo establish controls aligned with ISO/IEC 27001:2022.\n\n3. Scope:\nApplies to ${team}\n\n7. Evidence Provided:\n${evidenceText}\n\n--- END ---\n`;\n\nreturn [{ json: { document } }];"
      },
