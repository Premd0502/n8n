    {
      "parameters": {
        "functionCode": "const standard = $json.standard || \"ISO27001\";\nconst text = $json.text || \"\";\n\nconst prompts = {\n  ISO27001: `Generate ISO 27001:2022 Annex-A controls (93 controls).\nFor each control provide:\n- Control Name\n- Policy Coverage\n- Required Documents\n- Evidence Required\n- Audit Findings\n- Compliance Status\n- Risk Level\n- Recommendation`,\n\n  ISO27701: `Generate Privacy controls (PII handling, GDPR alignment). Include policy mapping, evidence, findings.`,\n\n  ISO27017: `Generate Cloud Security controls (shared responsibility, IAM, virtualization, cloud risks).`,\n\n  ISO42001: `Generate AI governance controls (bias, lifecycle, monitoring, ethics).`,\n\n  ISO23894: `Generate AI Risk Management controls (risk identification, mitigation).`,\n\n  SOC2: `Generate SOC 2 Type II controls (Security, Availability, Confidentiality). Include audit findings.`\n};\n\nreturn [{\n  prompt: prompts[standard],\n  standard,\n  text\n}];"
      },
      "id": "daddca3c-5e1f-49c4-a4d9-7a86bad47c8c",
      "name": "Build Control Generator Prompt",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        400,
        112
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "specifyHeaders": "json",
        "jsonHeaders": "{ \"Authorization\": \"Bearer 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\", \"Content-Type\": \"application/json\" }",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { model: 'llama-3.3-70b-versatile', messages: [ { role: 'system', content: $json.prompt }, { role: 'user', content: 'Policy Content: ' + $json.text } ], temperature: 0.2 } }}",
        "options": {}
      },
      "id": "6232142b-b136-4ff3-ae2b-bdda841f2649",
      "name": "AI Control Generator + Auditor",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        608,
