    {
      "parameters": {
        "functionCode": "return [{\n  html: `\n  <h1>${$json.standard} Audit Report</h1>\n\n  <h2>Summary</h2>\n  <p>Generated AI Audit Report</p>\n\n  <h2>Findings</h2>\n  <pre>${$json.choices[0].message.content}</pre>\n  `\n}];"
      },
